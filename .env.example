# Brew & Co Café — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to Git.

# ── Site URL (used for Google OAuth redirect) ────────────────────
VITE_SITE_URL=http://localhost:5173   # change to https://brewco.app in production

# ── Backend API ──────────────────────────────────
VITE_API_URL=http://localhost:4000

# ── Supabase ────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Razorpay (use test keys in dev) ─────────────
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx

# ── Google Maps ──────────────────────────────────
VITE_GOOGLE_MAPS_API_KEY=your-maps-key-here
