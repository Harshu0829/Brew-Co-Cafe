# ── Brew & Co Backend — Environment Variables ────────────────────────────
# Copy to .env and fill in real values. Never commit .env to Git.

# ── Server ──────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Supabase (use SERVICE ROLE key here — server-side only, never in frontend) ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── CORS — comma-separated allowed frontend origins ──────────────────────
ALLOWED_ORIGINS=http://localhost:5173

# ── Razorpay ─────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# ── JWT secret (same as Supabase JWT secret — for manual verification) ───
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
